@model Atividade_Nilson.Models.Usuario

@{
    ViewData["Title"] = "Detalhes do Usuário";
}

<h2 class="mb-4">Detalhes do Usuário</h2>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Código</dt>
            <dd class="col-sm-9">@Model.IdUsu</dd>

            <dt class="col-sm-3">Nome</dt>
            <dd class="col-sm-9">@Model.nomeUsu</dd>

            <dt class="col-sm-3">Cargo</dt>
            <dd class="col-sm-9">@Model.Cargo</dd>

            <dt class="col-sm-3">Data de Nascimento</dt>
            <dd class="col-sm-9">@Model.DataNasc.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">CEP</dt>
            <dd class="col-sm-9">@Model.CEP</dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">@Model.Estado</dd>

            <dt class="col-sm-3">Cidade</dt>
            <dd class="col-sm-9">@Model.Cidade</dd>

            <dt class="col-sm-3">Bairro</dt>
            <dd class="col-sm-9">@Model.Bairro</dd>

            <dt class="col-sm-3">Logradouro</dt>
            <dd class="col-sm-9">@Model.Logradouro</dd>

            <dt class="col-sm-3">Complemento</dt>
            <dd class="col-sm-9">@Model.Complemento</dd>

            <dt class="col-sm-3">Número</dt>
            <dd class="col-sm-9">@Model.Numero</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Usuario" asp-action="AtualizarUsuario" asp-route-id="@Model.IdUsu" class="btn btn-warning">
        Editar
    </a>
    <a asp-controller="Usuario" asp-action="Index" class="btn btn-secondary">
        Voltar
    </a>
</div>