@model IEnumerable<Atividade_Nilson.Models.Usuario>

@{
    ViewData["Title"] = "Lista de Usuários";
}

<h2 class="mb-4">Lista de Usuários</h2>

<p>
    <a asp-controller="Usuario" asp-action="CadastrarUsuario" class="btn btn-success">
        Novo Usuário
    </a>
</p>

<table class="table table-bordered table-striped table-hover">
    <thead>
        <tr>
            <th>Código</th>
            <th>Nome</th>
            <th>Cargo</th>
            <th>Nascimento</th>
            <th>CEP</th>
            <th>Estado</th>
            <th>Cidade</th>
            <th>Bairro</th>
            <th>Logradouro</th>
            <th>Complemento</th>
            <th>Número</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var usuario in Model)
        {
            <tr>
                <td>@usuario.IdUsu</td>
                <td>@usuario.nomeUsu</td>
                <td>@usuario.Cargo</td>
                <td>@usuario.DataNasc.ToString("dd/MM/yyyy")</td>
                <td>@usuario.CEP</td>
                <td>@usuario.Estado</td>
                <td>@usuario.Cidade</td>
                <td>@usuario.Bairro</td>
                <td>@usuario.Logradouro</td>
                <td>@usuario.Complemento</td>
                <td>@usuario.Numero</td>
                <td>
                    <a asp-controller="Usuario" asp-action="DetalhesUsuario" asp-route-id="@usuario.IdUsu" class="btn btn-secondary btn-sm">
                        Detalhes
                    </a>
                    <a asp-controller="Usuario" asp-action="AtualizarUsuario" asp-route-id="@usuario.IdUsu" class="btn btn-warning btn-sm">
                        Editar
                    </a>
                    <a asp-controller="Usuario" asp-action="ExcluirUsuario" asp-route-id="@usuario.IdUsu" class="btn btn-danger btn-sm">
                        Excluir
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>