@model Atividade_Nilson.Models.Endereco

@{
    ViewData["Title"] = "Detalhes";
}

<h2>Detalhes do Endereço</h2>

<hr />

<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">CEP</dt>
    <dd class="col-sm-10">@Model.CEP</dd>

    <dt class="col-sm-2">Estado</dt>
    <dd class="col-sm-10">@Model.Estado</dd>

    <dt class="col-sm-2">Cidade</dt>
    <dd class="col-sm-10">@Model.Cidade</dd>

    <dt class="col-sm-2">Bairro</dt>
    <dd class="col-sm-10">@Model.Bairro</dd>

    <dt class="col-sm-2">Logradouro</dt>
    <dd class="col-sm-10">@Model.Logradouro</dd>

    <dt class="col-sm-2">Complemento</dt>
    <dd class="col-sm-10">@Model.Complemento</dd>

    <dt class="col-sm-2">Número</dt>
    <dd class="col-sm-10">@Model.Numero</dd>
</dl>

<a asp-action="Index" class="btn btn-secondary">Voltar</a>
<a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>