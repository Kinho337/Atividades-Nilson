@model IEnumerable<Atividade_Nilson.Models.Endereco>

@{
    ViewData["Title"] = "Endereços Cadastrados";
}

<h2 class="mb-4">Endereços Cadastrados</h2>

<p>
    <a asp-controller="Endereco" asp-action="Cadastrar" class="btn btn-success">
        Novo Endereço
    </a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>CEP</th>
            <th>Estado</th>
            <th>Cidade</th>
            <th>Bairro</th>
            <th>Logradouro</th>
            <th>Complemento</th>
            <th>Número</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var endereco in Model)
        {
            <tr>
                <td>@endereco.Id</td>
                <td>@endereco.CEP</td>
                <td>@endereco.Estado</td>
                <td>@endereco.Cidade</td>
                <td>@endereco.Bairro</td>
                <td>@endereco.Logradouro</td>
                <td>@endereco.Complemento</td>
                <td>@endereco.Numero</td>
                <td>
                    <a asp-action="Detalhes" asp-route-id="@endereco.Id" class="btn btn-secondary btn-sm">
                        Detalhes
                    </a>
                    <a asp-action="Editar" asp-route-id="@endereco.Id" class="btn btn-warning btn-sm">
                        Editar
                    </a>
                    <a asp-action="Excluir" asp-route-id="@endereco.Id" class="btn btn-danger btn-sm">
                        Excluir
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>