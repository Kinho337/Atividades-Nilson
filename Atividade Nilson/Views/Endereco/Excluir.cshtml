@model Atividade_Nilson.Models.Endereco

@{
    ViewData["Title"] = "Excluir";
}

<h2>Excluir Endereço</h2>

<p>Tem certeza que deseja excluir este endereço?</p>

<hr />

<dl class="row">
    <dt class="col-sm-2">CEP</dt>
    <dd class="col-sm-10">@Model.CEP</dd>

    <dt class="col-sm-2">Cidade</dt>
    <dd class="col-sm-10">@Model.Cidade</dd>

    <dt class="col-sm-2">Logradouro</dt>
    <dd class="col-sm-10">@Model.Logradouro</dd>

    <dt class="col-sm-2">Número</dt>
    <dd class="col-sm-10">@Model.Numero</dd>
</dl>

<form asp-action="Excluir" method="post">
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Excluir</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>